---
openGraphImage: "/img/opengraph.png"
useP5: false
useDotLottie: false
---
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{metadata.studioname}} | {{title}}</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description | default: metadata.description }}">
    <meta name="author" content="{{metadata.author.name}}">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#000000">
    <link rel="canonical" href="{{metadata.baseURL}}{{page.url}}">

    <meta property="og:url" content="{{metadata.baseURL}}{{page.url}}" />
    <meta property="og:title" content="{{metadata.studioname}} | {{title}}" />
    <meta property="og:image" content="{{metadata.baseURL}}{{openGraphImage}}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:description" content="{{ description | default: metadata.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="{{metadata.studioname}}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{metadata.studioname}} | {{title}}" />
    <meta name="twitter:description" content="{{ description | default: metadata.description }}" />
    <meta name="twitter:image" content="{{metadata.baseURL}}{{openGraphImage}}" />

    <link rel="stylesheet" href="https://use.typekit.net/rli7dce.css">
    <link rel="stylesheet" href="/styles.css">

    <link rel="icon" type="image/png" href="/img/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="10k24" />
    <link rel="manifest" href="/img/site.webmanifest" />
    
    <!-- Schema Markup -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "{{metadata.studioname}}",
        "url": "{{metadata.baseURL}}",
        "description": "{{metadata.description}}",
        "sameAs": [
            "{{metadata.social.GitHub}}",
            "{{metadata.social.Instagram}}",
            "{{metadata.social.LinkedIn}}"
        ],
        "contactPoint": {
            "@type": "ContactPoint",
            "email": "{{metadata.author.email}}",
            "contactType": "general"
        }
    }
    </script>
    
    {% if useP5 %}
    <script src="https://cdn.jsdelivr.net/npm/p5@1.11.11/lib/p5.min.js"></script>
    {% endif %}
</head>
<body>
    <header>
        <div class="header-logo">
            <a href="/">
                <img class="header-logo" src="/img/10k24_shortform_logo.svg" alt="10k24 logo" draggable="false" />
            </a>
        </div>
        <nav>
            <div class="nav-item">
                <a href="/ideas">Ideas</a>
            </div>
            <div class="nav-item">
                <a href="/projects">Projects</a>
            </div>
            <div class="nav-item">
                <a href="mailto:{{metadata.author.email}}">Email Us</a>
            </div>
        </nav>
        <button class="menu-toggle" aria-label="Open menu">&#9776;</button>
        <button class="menu-close" aria-label="Close menu">&#10005;</button>
    </header>
    <div class="mobile-menu" role="dialog" aria-label="Navigation menu">
        <div class="menu-links">
            <a href="/">Home</a>
            <a href="/ideas">Ideas</a>
            <a href="/projects">Projects</a>
        </div>
        <br>
        <div class="menu-bottom">
            <a href="mailto:{{metadata.author.email}}">Email</a>
            <a href="{{metadata.social.GitHub}}" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="{{metadata.social.Instagram}}" target="_blank" rel="noopener noreferrer">Instagram</a>
        </div>
    </div>
    <main>
        {{ content }}
        <section class="section-last">
            <hr>
            <h2 class="footer-cta">Ready to work together?</h2>
            <div class="section-content">
                <div class="section-item">
                    <br />
                    <br />
                    <p>We work with a select few clients who believe in creating something memorable together. If&nbsp;this sounds like you, click the button below to tell us about your project. We read every form submission.</p>
                    <br>
                    <a class="btn" href="https://tally.so/r/KYkBPX" target="_blank" rel="noopener noreferrer">&rarr; Start a project</a>
                </div>
            </div>
            <hr>
        </section>
    </main>
    <!-- TODO: true sticky footer, nice corner composition on home page -->
    <footer>
        <p>&copy; <span id="year"></span> {{metadata.studioname}}. Los&nbsp;Angeles,&nbsp;California.</p>
        <div class="footer-links">
            <a href="{{metadata.social.GitHub}}" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="{{metadata.social.Instagram}}" target="_blank" rel="noopener noreferrer">Instagram</a>
            {% emailLink metadata.author.email %}
        </div>
    </footer>
    <script>document.getElementById('year').textContent = new Date().getFullYear();</script>
    <script>
        (function() {
            var toggle = document.querySelector('.menu-toggle');
            var close = document.querySelector('.menu-close');
            if (!toggle || !close) return;
            toggle.addEventListener('click', function() {
                document.body.classList.add('menu-open');
            });
            close.addEventListener('click', function() {
                document.body.classList.remove('menu-open');
            });
        })();
    </script>
    <script>
        (function() {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
            var observer = new IntersectionObserver(function(entries) {
                for (var i = 0; i < entries.length; i++) {
                    if (entries[i].isIntersecting) {
                        entries[i].target.classList.add('in-view');
                        observer.unobserve(entries[i].target);
                    }
                }
            });
            var items = document.querySelectorAll('.fade');
            for (var j = 0; j < items.length; j++) {
                observer.observe(items[j]);
            }
        })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CPZFEJK5BG"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-CPZFEJK5BG');
    </script>
    {% if useDotLottie %}
    <script
      src="https://unpkg.com/@lottiefiles/dotlottie-wc@latest/dist/dotlottie-wc.js"
      type="module"
    ></script>
    {% endif %}
    {% if useP5 %}
    <script>
        // Load unique sketch scripts and instantiate all p5 sketches
        window.sketches = window.sketches || {};
        
        const containers = document.querySelectorAll('[data-sketch-file]');
        const uniqueSources = new Set();
        
        // Collect unique sketch sources
        containers.forEach(function(container) {
            const src = container.dataset.sketchSrc;
            if (src) uniqueSources.add(src);
        });
        
        // Load scripts sequentially
        let loadPromise = Promise.resolve();
        uniqueSources.forEach(function(src) {
            loadPromise = loadPromise.then(function() {
                return new Promise(function(resolve) {
                    const script = document.createElement('script');
                    script.src = src;
                    script.onload = resolve;
                    document.body.appendChild(script);
                });
            });
        });
        
        // After all scripts loaded, instantiate sketches
        loadPromise.then(function() {
            containers.forEach(function(container) {
                const sketchFile = container.dataset.sketchFile;
                const containerId = sketchFile + '-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
                container.id = containerId;
                if (window.sketches[sketchFile]) {
                    window.sketches[containerId] = window.sketches[sketchFile];
                }
            });
            
            for (let s of Object.keys(window.sketches)) {
                if (document.getElementById(s)) {
                    new p5(window.sketches[s], s);
                }
            }
        });
    </script>
    {% endif %}
</body>
</html>