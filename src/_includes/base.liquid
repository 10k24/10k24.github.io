---
openGraphImage: "/img/opengraph.png"
---

<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{metadata.longname}}| {{title}}</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{description}}">
    <meta name="author" content="{{metadata.author}}">

    <meta property="og:url" content="{{metadata.baseURL}}{{page.url}}" />
    <meta property="og:title" content="{{metadata.longname}} | {{title}}" />
    <meta property="og:image" content="{{metadata.baseURL}}{{openGraphImage}}" />
    <meta property="og:description" content="{{description}}" />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />

    <link rel="stylesheet" href="https://use.typekit.net/rli7dce.css">
    <link rel="stylesheet" href="/styles.css">

    <link rel="icon" type="image/png" href="/img/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="10k24" />
    <link rel="manifest" href="/img/site.webmanifest" />
    
    <!-- TODO: schema markup -->
    
    {% if multiSketch %}
    <!-- Multi-sketch mode: load p5.js once for the entire page -->
    <script src="https://cdn.jsdelivr.net/npm/p5@1.11.11/lib/p5.min.js"></script>
    {% else %}
    <!-- Single sketch mode: load p5.js once -->
    <script src="https://cdn.jsdelivr.net/npm/p5@1.11.11/lib/p5.min.js"></script>
    {% endif %}
</head>
<body>
    <header>
        <div class="header-logo">
            <a href="/">
                <img class="header-logo" src="/img/10k24_shortform_logo.svg" draggable="false" />
            </a>
        </div>
        <nav>
            <!-- <div class="nav-item">
                <a href="/">Home</a>
            </div> -->
            <!-- <div class="nav-item">
                <a href="/projects">Projects</a>
            </div> -->
            <!-- <div class="nav-item">
                <a href="/ideas"></a>
            </div>
            <div class="nav-item">
                <a href="/about"></a>
            </div> -->
            <div class="nav-item">
                <a href="mailto:info@10k24.com">Email Us</a>
            </div>
        </nav>
    </header>
    <main>
        {{ content }}
    </main>
    <footer>
        <p>&copy; <script>document.write((new Date()).getFullYear());</script> {{metadata.author}}.</p>
        <div class="footer-links">
            <p><a href="https://github.com/10k24" target=_blank>GitHub</a></p>
            <p><a href="https://instagram.com/10k24.studio" target=_blank>Instagram</a></p>
            <p><a href="mailto:info@10k24.com">info@10k24.com</a></p>
        </div>
    </footer>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CPZFEJK5BG"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-CPZFEJK5BG');
    </script>
    <script>
        // Load unique sketch scripts and instantiate all p5 sketches
        window.sketches = window.sketches || {};
        
        const containers = document.querySelectorAll('[data-sketch-file]');
        const uniqueSources = new Set();
        
        // Collect unique sketch sources
        containers.forEach(function(container) {
            const src = container.dataset.sketchSrc;
            if (src) uniqueSources.add(src);
        });
        
        // Load scripts sequentially
        let loadPromise = Promise.resolve();
        uniqueSources.forEach(function(src) {
            loadPromise = loadPromise.then(function() {
                return new Promise(function(resolve) {
                    const script = document.createElement('script');
                    script.src = src;
                    script.onload = resolve;
                    document.body.appendChild(script);
                });
            });
        });
        
        // After all scripts loaded, instantiate sketches
        loadPromise.then(function() {
            containers.forEach(function(container) {
                const sketchFile = container.dataset.sketchFile;
                const containerId = sketchFile + '-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
                container.id = containerId;
                if (window.sketches[sketchFile]) {
                    window.sketches[containerId] = window.sketches[sketchFile];
                }
            });
            
            for (let s of Object.keys(window.sketches)) {
                if (document.getElementById(s)) {
                    new p5(window.sketches[s], s);
                }
            }
        });
    </script>
</body>
</html>